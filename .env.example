# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# Google OAuth — luo credentials.json Google Cloud Consolessa
# ja aja: python -m backend.auth_setup
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# ScrapingBee — tarvitaan sivuille joilla render_js: true (esim. Cloudflare-suojatut)
# Ilmainen tili: https://www.scrapingbee.com
SCRAPINGBEE_API_KEY=
